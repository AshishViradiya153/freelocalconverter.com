## Contact form email (SMTP)
## IMPORTANT: Never commit real credentials. Copy to `.env.local` and fill values there.
CONTACT_SMTP_HOST=
CONTACT_SMTP_PORT=587
CONTACT_SMTP_SECURE=false
CONTACT_SMTP_USER=
CONTACT_SMTP_PASS=
## Comma-separated recipients (preferred), e.g. admin1@example.com,admin2@example.com
ADMIN_MAILS=
## Legacy single-recipient fallback
CONTACT_MAIL_TO=

NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=

NODE_ENV=